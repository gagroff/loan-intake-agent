# Copy to `.env` (which is git-ignored) and fill in from your Microsoft Foundry project.
# NEVER commit the real .env.

# --- Microsoft Foundry (Azure AI Foundry) project ---
# Found on the Foundry project Home page after deploying models.
# Auth is via `az login` (AzureCliCredential) -- no API key needed in code.
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-name>

# Deployment names you gave the models when deploying them in the portal.
FOUNDRY_CHAT_DEPLOYMENT=gpt-5-mini
FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-small
